{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "patterns/**", "tsconfig.json", "tsup.config.ts", "package.json"],
      "outputs": ["dist/**"]
    },
    "build#@toucan-ui/tokens": {
      "inputs": ["presets/**/*.json"],
      "outputs": []
    },
    "build#@toucan-ui/docs": {
      "dependsOn": ["^build"],
      "inputs": ["app/**", "themes/**", "next.config.ts", "tsconfig.json", "package.json"],
      "outputs": [".next/**"],
      "env": ["NEXT_PUBLIC_*"]
    },
    "build#@toucan-ui/wizard": {
      "dependsOn": ["^build"],
      "inputs": [
        "app/**",
        "components/**",
        "lib/**",
        "next.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": [".next/**"],
      "env": ["NEXT_PUBLIC_*"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "patterns/**", "app/**", "components/**", "lib/**", "*.config.*"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "patterns/**", "app/**", "components/**", "lib/**", "tsconfig.json"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "patterns/**", "vitest.config.*"]
    },
    "clean": {
      "cache": false
    }
  }
}
