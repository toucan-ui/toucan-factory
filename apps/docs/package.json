    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.13",
    "@types/node": "25.3.3",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "style-dictionary": "^5.4.0",
