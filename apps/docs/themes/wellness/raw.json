{
  "color": {
    "sage": {
      "50": { "$value": "#f3f6f3", "$type": "color" },
      "100": { "$value": "#e4ebe5", "$type": "color" },
      "200": { "$value": "#c9d7cb", "$type": "color" },
      "300": { "$value": "#a3b9a6", "$type": "color" },
      "400": { "$value": "#7d9b81", "$type": "color" },
      "500": { "$value": "#6b8f71", "$type": "color" },
      "600": { "$value": "#4e7254", "$type": "color" },
      "700": { "$value": "#3e5b43", "$type": "color" },
      "800": { "$value": "#344a38", "$type": "color" },
      "900": { "$value": "#2c3e30", "$type": "color" },
      "950": { "$value": "#152018", "$type": "color" }
    },
    "cream": {
      "0": { "$value": "#fffdf9", "$type": "color" },
      "50": { "$value": "#fdfbf7", "$type": "color" },
      "100": { "$value": "#f9f5ed", "$type": "color" },
      "200": { "$value": "#f2ebdd", "$type": "color" }
    },
    "white": { "$value": "#ffffff", "$type": "color" }
  },
  "shadow": {
    "wellness": {
      "sm": { "$value": "0 2px 8px -2px rgba(107, 143, 113, 0.12)", "$type": "shadow" },
      "md": {
        "$value": "0 6px 16px -4px rgba(107, 143, 113, 0.14), 0 2px 6px -2px rgba(107, 143, 113, 0.08)",
        "$type": "shadow"
      },
      "lg": {
        "$value": "0 12px 32px -8px rgba(107, 143, 113, 0.16), 0 4px 12px -4px rgba(107, 143, 113, 0.08)",
        "$type": "shadow"
      },
      "dark": {
        "sm": { "$value": "0 2px 8px -2px rgba(0, 0, 0, 0.25)", "$type": "shadow" },
        "md": {
          "$value": "0 6px 16px -4px rgba(0, 0, 0, 0.3), 0 2px 6px -2px rgba(0, 0, 0, 0.2)",
          "$type": "shadow"
        },
        "lg": {
          "$value": "0 12px 32px -8px rgba(0, 0, 0, 0.35), 0 4px 12px -4px rgba(0, 0, 0, 0.2)",
          "$type": "shadow"
        }
      }
    }
  }
}
