{
  "color": {
    "slate": {
      "50": { "$value": "#f8fafc", "$type": "color" },
      "100": { "$value": "#f1f5f9", "$type": "color" },
      "200": { "$value": "#e2e8f0", "$type": "color" },
      "300": { "$value": "#cbd5e1", "$type": "color" },
      "400": { "$value": "#94a3b8", "$type": "color" },
      "500": { "$value": "#64748b", "$type": "color" },
      "700": { "$value": "#334155", "$type": "color" },
      "800": { "$value": "#1e293b", "$type": "color" },
      "900": { "$value": "#0f172a", "$type": "color" },
      "950": { "$value": "#020617", "$type": "color" }
    },
    "blue": {
      "500": { "$value": "#3b82f6", "$type": "color" },
      "600": { "$value": "#2563eb", "$type": "color" },
      "700": { "$value": "#1d4ed8", "$type": "color" }
    },
    "white": { "$value": "#ffffff", "$type": "color" }
  },
  "shadow": {
    "finance": {
      "sm": { "$value": "0 1px 2px 0 rgba(15, 23, 42, 0.04)", "$type": "shadow" },
      "md": {
        "$value": "0 2px 4px -1px rgba(15, 23, 42, 0.06), 0 1px 2px -1px rgba(15, 23, 42, 0.04)",
        "$type": "shadow"
      },
      "lg": {
        "$value": "0 4px 8px -2px rgba(15, 23, 42, 0.08), 0 2px 4px -2px rgba(15, 23, 42, 0.04)",
        "$type": "shadow"
      },
      "dark": {
        "sm": { "$value": "0 1px 2px 0 rgba(0, 0, 0, 0.2)", "$type": "shadow" },
        "md": {
          "$value": "0 2px 4px -1px rgba(0, 0, 0, 0.3), 0 1px 2px -1px rgba(0, 0, 0, 0.2)",
          "$type": "shadow"
        },
        "lg": {
          "$value": "0 4px 8px -2px rgba(0, 0, 0, 0.4), 0 2px 4px -2px rgba(0, 0, 0, 0.2)",
          "$type": "shadow"
        }
      }
    }
  }
}
