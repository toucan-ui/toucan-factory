{
  "name": "@toucan-ui/core",
  "version": "0.2.0",
  "description": "Accessible React component primitives and token-to-CSS build pipeline for ToucanUI",
  "license": "MIT",
  "keywords": [
    "design-system",
    "toucanui",
    "react",
    "accessible-components",
    "primitives"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "bin": {
    "toucan": "./dist/bin/toucan.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./config": {
      "types": "./dist/cli/config.d.ts",
      "import": "./dist/cli/config.js"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/components/**/*.css",
    "src/components/**/*.css.tpl",
    "src/utils/**/*.css"
  ],
  "scripts": {
    "prepare": "mkdir -p dist/bin && [ -f dist/bin/toucan.js ] || printf '#!/usr/bin/env node\\nconsole.error(\"@toucan-ui/core not built yet — run: pnpm turbo build --filter=@toucan-ui/core\");process.exit(1);' > dist/bin/toucan.js",
    "build": "tsup",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@toucan-ui/interactions": "workspace:*",
    "style-dictionary": "^5.3.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.1",
    "vitest-axe": "^0.1.0"
  }
}
