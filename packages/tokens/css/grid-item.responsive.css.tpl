/* GridItem responsive — breakpoint-driven span overrides */
/* Generated from grid-item.responsive.css.tpl at build time */

/* --- sm --- */
@media (min-width: @[breakpoint.sm]) {
  .factory-grid-item[data-span-sm='1']  { grid-column: span 1; }
  .factory-grid-item[data-span-sm='2']  { grid-column: span 2; }
  .factory-grid-item[data-span-sm='3']  { grid-column: span 3; }
  .factory-grid-item[data-span-sm='4']  { grid-column: span 4; }
