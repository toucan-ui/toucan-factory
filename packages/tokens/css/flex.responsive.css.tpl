/* Flex responsive — breakpoint-driven direction, alignment, and justification */
/* Generated from flex.responsive.css.tpl at build time */

@media (min-width: @[breakpoint.sm]) {
  .factory-flex[data-row='sm'] { flex-direction: row; }

  .factory-flex[data-align-sm='start'] { align-items: flex-start; }
  .factory-flex[data-align-sm='center'] { align-items: center; }
  .factory-flex[data-align-sm='end'] { align-items: flex-end; }
  .factory-flex[data-align-sm='stretch'] { align-items: stretch; }
  .factory-flex[data-align-sm='baseline'] { align-items: baseline; }

  .factory-flex[data-justify-sm='start'] { justify-content: flex-start; }
  .factory-flex[data-justify-sm='center'] { justify-content: center; }
  .factory-flex[data-justify-sm='end'] { justify-content: flex-end; }
  .factory-flex[data-justify-sm='between'] { justify-content: space-between; }
}

