{
  "select": {
    "trigger": {
      "surface": {
        "default": { "$value": "{color.surface.default}", "$type": "color" },
        "disabled": { "$value": "{color.disabled}", "$type": "color" }
      },
      "on-surface": {
        "default": { "$value": "{color.on-surface.default}", "$type": "color" },
        "placeholder": { "$value": "{color.on-surface.muted}", "$type": "color" },
        "disabled": { "$value": "{color.on-disabled}", "$type": "color" }
      },
      "border": {
        "default": { "$value": "{color.border.default}", "$type": "color" },
        "hover": { "$value": "{color.border.strong}", "$type": "color" },
        "focus": { "$value": "{color.border.focus}", "$type": "color" },
        "error": { "$value": "{color.danger}", "$type": "color" }
      },
      "radius": { "$value": "{radius.md}", "$type": "dimension" },
      "padding-x": { "$value": "{spacing.md}", "$type": "dimension" },
      "padding-y": { "$value": "{spacing.sm}", "$type": "dimension" },
      "font-size": { "$value": "{font.size.base}", "$type": "dimension" },
      "border-width": { "$value": "{border-width.thin}", "$type": "dimension" },
      "min-height": { "$value": "{sizing.lg}", "$type": "dimension" },
      "icon-size": { "$value": "{sizing.2xs}", "$type": "dimension" },
      "chevron-size": { "$value": "{scale.2}", "$type": "dimension" },
      "chevron-weight": { "$value": "{scale.0-5}", "$type": "dimension" },
      "chevron-offset": { "$value": "{scale.0-25}", "$type": "dimension" }
    },
    "listbox": {
      "surface": { "$value": "{color.surface.raised}", "$type": "color" },
      "border": { "$value": "{color.border.default}", "$type": "color" },
      "border-width": { "$value": "{border-width.thin}", "$type": "dimension" },
      "radius": { "$value": "{radius.md}", "$type": "dimension" },
      "padding-y": { "$value": "{spacing.xs}", "$type": "dimension" },
      "shadow": { "$value": "{shadow.md}", "$type": "shadow" },
      "max-height": { "$value": "{layout.60}", "$type": "dimension" },
      "z-index": { "$value": "{stacking.dropdown}", "$type": "number" }
    },
    "option": {
      "padding-x": { "$value": "{spacing.md}", "$type": "dimension" },
      "padding-y": { "$value": "{spacing.sm}", "$type": "dimension" },
      "font-size": { "$value": "{font.size.base}", "$type": "dimension" },
      "radius": { "$value": "{radius.sm}", "$type": "dimension" },
      "surface": {
        "default": { "$value": "{color.transparent}", "$type": "color" },
        "active": { "$value": "{color.surface.muted}", "$type": "color" },
        "selected": { "$value": "{color.surface.muted}", "$type": "color" }
      },
      "on-surface": {
        "default": { "$value": "{color.on-surface.default}", "$type": "color" },
        "disabled": { "$value": "{color.on-disabled}", "$type": "color" }
      }
    },
    "gap": { "$value": "{spacing.xs}", "$type": "dimension" },
    "trigger-gap": { "$value": "{spacing.sm}", "$type": "dimension" },
    "label-font-weight": { "$value": "{font.weight.medium}", "$type": "fontWeight" },
    "listbox-margin-top": { "$value": "{spacing.xs}", "$type": "dimension" },
    "option-margin-x": { "$value": "{spacing.xs}", "$type": "dimension" }
  }
}
