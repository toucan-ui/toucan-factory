{
  "badge": {
    "neutral": {
      "surface": { "$value": "{color.surface.muted}", "$type": "color" },
      "on-surface": { "$value": "{color.on-surface.default}", "$type": "color" }
    },
    "success": {
      "surface": { "$value": "{color.success-surface}", "$type": "color" },
      "on-surface": { "$value": "{color.on-success-surface}", "$type": "color" }
    },
    "warning": {
      "surface": { "$value": "{color.warning-surface}", "$type": "color" },
      "on-surface": { "$value": "{color.on-warning-surface}", "$type": "color" }
    },
    "danger": {
      "surface": { "$value": "{color.danger-surface}", "$type": "color" },
      "on-surface": { "$value": "{color.on-danger-surface}", "$type": "color" }
    },
    "info": {
      "surface": { "$value": "{color.info-surface}", "$type": "color" },
      "on-surface": { "$value": "{color.on-info-surface}", "$type": "color" }
    },
    "radius": { "$value": "{radius.md}", "$type": "dimension" },
    "font-weight": { "$value": "{font.weight.medium}", "$type": "fontWeight" },
    "sm": {
      "padding-x": { "$value": "{spacing.sm}", "$type": "dimension" },
      "padding-y": { "$value": "{spacing.none}", "$type": "dimension" },
      "font-size": { "$value": "{font.size.xs}", "$type": "dimension" }
    },
    "md": {
      "padding-x": { "$value": "{spacing.md}", "$type": "dimension" },
      "padding-y": { "$value": "{spacing.xs}", "$type": "dimension" },
      "font-size": { "$value": "{font.size.sm}", "$type": "dimension" }
    },
    "lg": {
      "padding-x": { "$value": "{spacing.lg}", "$type": "dimension" },
      "padding-y": { "$value": "{spacing.xs}", "$type": "dimension" },
      "font-size": { "$value": "{font.size.base}", "$type": "dimension" }
    }
  }
}
