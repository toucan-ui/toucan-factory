{
  "button": {
    "primary": {
      "surface": {
        "default": { "$value": "{color.primary}", "$type": "color" },
        "hover": { "$value": "{color.primary-hover}", "$type": "color" },
        "active": { "$value": "{color.primary-active}", "$type": "color" }
      },
      "on-surface": {
        "default": { "$value": "{color.on-primary}", "$type": "color" },
        "hover": { "$value": "{color.on-primary}", "$type": "color" },
        "active": { "$value": "{color.on-primary}", "$type": "color" }
      },
      "border": {
        "default": { "$value": "{color.transparent}", "$type": "color" },
        "hover": { "$value": "{color.transparent}", "$type": "color" },
        "active": { "$value": "{color.transparent}", "$type": "color" }
      }
    },
    "secondary": {
      "surface": {
        "default": { "$value": "{color.surface.default}", "$type": "color" },
        "hover": { "$value": "{color.surface.muted}", "$type": "color" },
        "active": { "$value": "{color.surface.muted}", "$type": "color" }
      },
      "on-surface": {
        "default": { "$value": "{color.on-surface.default}", "$type": "color" },
        "hover": { "$value": "{color.on-surface.default}", "$type": "color" },
        "active": { "$value": "{color.on-surface.default}", "$type": "color" }
      },
      "border": {
        "default": { "$value": "{color.border.default}", "$type": "color" },
        "hover": { "$value": "{color.border.strong}", "$type": "color" },
        "active": { "$value": "{color.border.strong}", "$type": "color" }
      }
    },
    "ghost": {
      "surface": {
        "default": { "$value": "{color.transparent}", "$type": "color" },
        "hover": { "$value": "{color.surface.muted}", "$type": "color" },
        "active": { "$value": "{color.surface.muted}", "$type": "color" }
      },
      "on-surface": {
        "default": { "$value": "{color.on-surface.default}", "$type": "color" },
        "hover": { "$value": "{color.on-surface.default}", "$type": "color" },
        "active": { "$value": "{color.on-surface.default}", "$type": "color" }
      },
      "border": {
        "default": { "$value": "{color.transparent}", "$type": "color" },
        "hover": { "$value": "{color.transparent}", "$type": "color" },
        "active": { "$value": "{color.transparent}", "$type": "color" }
      }
    },
    "disabled": {
      "surface": { "$value": "{color.disabled}", "$type": "color" },
      "on-surface": { "$value": "{color.on-disabled}", "$type": "color" },
      "border": { "$value": "{color.transparent}", "$type": "color" }
    },
    "radius": { "$value": "{radius.md}", "$type": "dimension" },
    "font-weight": { "$value": "{font.weight.medium}", "$type": "fontWeight" },
    "sm": {
      "padding-x": { "$value": "{spacing.md}", "$type": "dimension" },
      "padding-y": { "$value": "{spacing.xs}", "$type": "dimension" },
      "font-size": { "$value": "{font.size.sm}", "$type": "dimension" },
      "height": { "$value": "{sizing.md}", "$type": "dimension" }
    },
    "md": {
      "padding-x": { "$value": "{spacing.lg}", "$type": "dimension" },
      "padding-y": { "$value": "{spacing.sm}", "$type": "dimension" },
      "font-size": { "$value": "{font.size.base}", "$type": "dimension" },
      "height": { "$value": "{sizing.lg}", "$type": "dimension" }
    },
    "lg": {
      "padding-x": { "$value": "{spacing.xl}", "$type": "dimension" },
      "padding-y": { "$value": "{spacing.md}", "$type": "dimension" },
      "font-size": { "$value": "{font.size.lg}", "$type": "dimension" },
      "height": { "$value": "{sizing.xl}", "$type": "dimension" }
    },
    "border-width": { "$value": "{border-width.thin}", "$type": "dimension" },
    "gap": { "$value": "{spacing.sm}", "$type": "dimension" },
    "loading-opacity": { "$value": "{opacity.70}", "$type": "number" }
  }
}
